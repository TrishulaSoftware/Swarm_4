# TRISHULA SOVEREIGN SWARM — Environment Variables
# ===================================================
# Copy this file to .env and fill in your credentials.
# NEVER commit the actual .env file.
# All values below are placeholders — replace with real credentials.

# ── OCI VAULT (Always Free: 150 secrets, 20 keys) ──────────────────────────
OCI_VAULT_OCID=YOUR_OCI_VAULT_OCID_HERE
OCI_VAULT_MANAGEMENT_EP=YOUR_OCI_VAULT_MANAGEMENT_EP_HERE
OCI_VAULT_CRYPTO_EP=YOUR_OCI_VAULT_CRYPTO_EP_HERE

# ── OCI VAULT MASTER KEY ─────────────────────────────────────────────────────
OCI_VAULT_KEY_OCID=YOUR_OCI_VAULT_KEY_OCID_HERE
OCI_VAULT_KEY_VERSION=YOUR_OCI_VAULT_KEY_VERSION_HERE

# ── OCI FUNCTIONS ─────────────────────────────────────────────────────────────
OCI_FUNCTIONS_APP_OCID=YOUR_OCI_FUNCTIONS_APP_OCID_HERE
OCI_FUNCTIONS_REGION=us-ashburn-1

# ── OCI NOTIFICATIONS ─────────────────────────────────────────────────────────
OCI_NOTIFICATIONS_TOPIC_OCID=YOUR_OCI_NOTIFICATIONS_TOPIC_OCID_HERE

# ── OCI NOSQL (Always Free: 25GB, 50RU/50WU) ─────────────────────────────────
OCI_NOSQL_TABLE_OCID=YOUR_OCI_NOSQL_TABLE_OCID_HERE
OCI_NOSQL_TABLE_NAME=swarm_events
OCI_NOSQL_REGION=us-ashburn-1

# ── OCI LOAD BALANCER + LOGGING (Always Free) ────────────────────────────────
OCI_LOAD_BALANCER_OCID=YOUR_OCI_LOAD_BALANCER_OCID_HERE
OCI_LOG_GROUP_OCID=YOUR_OCI_LOG_GROUP_OCID_HERE

# ── OCI STREAMING ─────────────────────────────────────────────────────────────
OCI_STREAM_OCID=YOUR_OCI_STREAM_OCID_HERE
OCI_STREAM_NAME=trishula-events-stream

# ── OCI API GATEWAY ───────────────────────────────────────────────────────────
OCI_API_GATEWAY_OCID=YOUR_OCI_API_GATEWAY_OCID_HERE
OCI_API_GATEWAY_NAME=trishula-api-gw

# ── OCI QUEUE ─────────────────────────────────────────────────────────────────
OCI_QUEUE_OCID=YOUR_OCI_QUEUE_OCID_HERE
OCI_QUEUE_NAME=trishula-signal-queue

# ── OCI AUTONOMOUS DB (Always Free: 2x 20GB, APEX, ORDS) ────────────────────
OCI_DB1_CONNECTION_STRING=YOUR_OCI_DB1_CONNECTION_STRING_HERE
OCI_DB2_CONNECTION_STRING=YOUR_OCI_DB2_CONNECTION_STRING_HERE
OCI_DB_USERNAME=YOUR_OCI_DB_USERNAME_HERE
OCI_DB_PASSWORD=YOUR_OCI_DB_PASSWORD_HERE

# ── AWS CREDENTIALS ───────────────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=YOUR_AWS_ACCESS_KEY_ID_HERE
AWS_SECRET_ACCESS_KEY=YOUR_AWS_SECRET_ACCESS_KEY_HERE
AWS_DEFAULT_REGION=us-east-2

# ── AWS PUBLIC EXPOSURE (Always Free) ─────────────────────────────────────────
AWS_CLOUDFRONT_ID=YOUR_AWS_CLOUDFRONT_ID_HERE
AWS_CLOUDFRONT_URL=YOUR_AWS_CLOUDFRONT_URL_HERE
AWS_API_GATEWAY_ID=YOUR_AWS_API_GATEWAY_ID_HERE
AWS_API_GATEWAY_URL=YOUR_AWS_API_GATEWAY_URL_HERE

# ── AWS SNS / SQS ─────────────────────────────────────────────────────────────
AWS_SNS_TOPIC_ARN=arn:aws:sns:us-east-2:YOUR_ACCOUNT_ID:trishula-alerts
AWS_SQS_QUEUE_URL=https://sqs.us-east-2.amazonaws.com/YOUR_ACCOUNT_ID/trishula-discord

# ── AWS STEP FUNCTIONS (4K transitions/mo free) ───────────────────────────────
AWS_STATE_MACHINE_ARN=YOUR_AWS_STATE_MACHINE_ARN_HERE
AWS_STATE_MACHINE_NAME=trishula-sovereign-orchestrator

# ── AWS LEX V2 ─────────────────────────────────────────────────────────────────
AWS_LEX_BOT_NAME=trishula-signal-bot
AWS_LEX_REGION=us-east-1

# ── AWS KILL SWITCH ─────────────────────────────────────────────────────────────
AWS_KILL_LAMBDA_ARN=arn:aws:lambda:us-east-2:YOUR_ACCOUNT_ID:function:trishula-trial-killshot
AWS_FORECAST_KILL_DATE=2026-08-25
AWS_SAGEMAKER_KILL_DATE=2026-07-26

# ── GCP CREDENTIALS ───────────────────────────────────────────────────────────
GOOGLE_APPLICATION_CREDENTIALS=YOUR_PATH_TO_GCP_KEY_JSON_HERE
GCP_PROJECT_ID=YOUR_GCP_PROJECT_ID_HERE
GCP_REGION=us-central1

# ── GCP CLOUD RUN FUNCTION (2M req/mo free) ───────────────────────────────────
GCP_CLOUD_FUNCTION_NAME=trishula-swarm-fn
GCP_CLOUD_FUNCTION_URL=YOUR_GCP_CLOUD_FUNCTION_URL_HERE
GCP_CLOUD_FUNCTION_REGION=us-central1

# ── GCP FIRESTORE (1GB free, 50K reads/day) ────────────────────────────────────
GCP_FIRESTORE_DB=trishula-swarm
GCP_FIRESTORE_REGION=nam5

# ── GCP CLOUD TASKS (1M tasks/mo free) ────────────────────────────────────────
GCP_TASKS_QUEUE=trishula-task-queue
GCP_TASKS_LOCATION=us-central1
GCP_TASKS_QUEUE_PATH=YOUR_GCP_TASKS_QUEUE_PATH_HERE

# ── GCP CLOUD MONITORING ──────────────────────────────────────────────────────
GCP_MONITORING_PROJECT=YOUR_GCP_PROJECT_ID_HERE
GCP_MONITORING_STATUS=LIVE

# ── GCP PUB/SUB ───────────────────────────────────────────────────────────────
GCP_PUBSUB_TOPIC=trishula-picks
GCP_PUBSUB_SUBSCRIPTION=trishula-picks-sub

# ── AZURE CREDENTIALS ─────────────────────────────────────────────────────────
AZURE_SUBSCRIPTION_ID=YOUR_AZURE_SUBSCRIPTION_ID_HERE
AZURE_TENANT_ID=YOUR_AZURE_TENANT_ID_HERE
AZURE_CLIENT_ID=YOUR_AZURE_CLIENT_ID_HERE
AZURE_CLIENT_SECRET=YOUR_AZURE_CLIENT_SECRET_HERE
AZURE_RESOURCE_GROUP=YOUR_AZURE_RESOURCE_GROUP_HERE

# ── AZURE COSMOS DB ───────────────────────────────────────────────────────────
AZURE_COSMOS_KEY=YOUR_AZURE_COSMOS_KEY_HERE
AZURE_COSMOS_ENDPOINT=YOUR_AZURE_COSMOS_ENDPOINT_HERE
AZURE_COSMOS_DB_NAME=trishula-swarm

# ── AZURE CONTAINER APP (Always Free: 180K vCPU-sec/mo) ──────────────────────
AZURE_CONTAINER_APP_NAME=trishula-containers
AZURE_CONTAINER_APP_REGION=westus

# ── AZURE FUNCTION APP (1M req/mo free) ───────────────────────────────────────
AZURE_FUNCTION_APP_NAME=trishula-functions
AZURE_FUNCTION_APP_URL=YOUR_AZURE_FUNCTION_APP_URL_HERE
AZURE_FUNCTION_APP_REGION=centralus

# ── AZURE KEY VAULT (Standard - secrets management) ───────────────────────────
AZURE_KEY_VAULT_NAME=trishulakeyvaultazure
AZURE_KEY_VAULT_URI=YOUR_AZURE_KEY_VAULT_URI_HERE

# ── AZURE COGNITIVE SERVICES ──────────────────────────────────────────────────
AZURE_COGNITIVE_ENDPOINT=YOUR_AZURE_COGNITIVE_ENDPOINT_HERE
AZURE_COGNITIVE_KEY=YOUR_AZURE_COGNITIVE_KEY_HERE
AZURE_SPEECH_KEY=YOUR_AZURE_SPEECH_KEY_HERE
AZURE_SPEECH_REGION=eastus

# ── DISCORD ───────────────────────────────────────────────────────────────────
DISCORD_WEBHOOK_PICKS=YOUR_DISCORD_WEBHOOK_PICKS_HERE
DISCORD_WEBHOOK_EARNINGS=YOUR_DISCORD_WEBHOOK_EARNINGS_HERE
DISCORD_WEBHOOK_ALERTS=YOUR_DISCORD_WEBHOOK_ALERTS_HERE
DISCORD_WEBHOOK_MACRO=YOUR_DISCORD_WEBHOOK_MACRO_HERE
DISCORD_WEBHOOK_CRYPTO=YOUR_DISCORD_WEBHOOK_CRYPTO_HERE
DISCORD_WEBHOOK_PARLAY=YOUR_DISCORD_WEBHOOK_PARLAY_HERE
DISCORD_WEBHOOK_PROPS=YOUR_DISCORD_WEBHOOK_PROPS_HERE
DISCORD_WEBHOOK_GEX=YOUR_DISCORD_WEBHOOK_GEX_HERE
DISCORD_WEBHOOK_WHALE=YOUR_DISCORD_WEBHOOK_WHALE_HERE
DISCORD_WEBHOOK_MLBSBM=YOUR_DISCORD_WEBHOOK_MLBSBM_HERE
DISCORD_WEBHOOK_GENERAL=YOUR_DISCORD_WEBHOOK_GENERAL_HERE

# ── MARKET DATA ───────────────────────────────────────────────────────────────
POLYGON_API_KEY=YOUR_POLYGON_API_KEY_HERE
ALPHA_VANTAGE_KEY=YOUR_ALPHA_VANTAGE_KEY_HERE
TRADIER_API_KEY=YOUR_TRADIER_API_KEY_HERE
TRADIER_ACCOUNT_ID=YOUR_TRADIER_ACCOUNT_ID_HERE

# ── GEMINI / GOOGLE AI ────────────────────────────────────────────────────────
GEMINI_API_KEY=YOUR_GEMINI_API_KEY_HERE
GEMINI_MODEL=gemini-2.5-pro-preview-05-06
